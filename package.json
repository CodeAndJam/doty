{
  "name": "doty",
  "version": "2.1.1",
  "description": "Continuous STT + AI music recommender",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "rebuild": "electron-rebuild --only sherpa-onnx-node,better-sqlite3",
    "copy-wasm": "node -e \"const fs=require('fs');fs.copyFileSync('node_modules/onnxruntime-web/dist/ort-wasm-simd-threaded.wasm','public/ort-wasm-simd-threaded.wasm')\"",
    "postinstall": "pnpm run rebuild && pnpm run copy-wasm",
    "dist": "pnpm run build && electron-builder --mac dmg",
    "pack": "electron-builder --mac dmg",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.codeandjam.doty",
    "productName": "Doty",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/essentia.js/dist/**",
      "node_modules/better-sqlite3/**",
      "node_modules/@discordjs/opus/**",
      "node_modules/sodium-native/**",
      "node_modules/opusscript/**",
      "node_modules/prism-media/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/sherpa-onnx-node",
        "to": "sherpa-onnx-node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Doty ${version}"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "better-sqlite3",
      "electron",
      "esbuild",
      "ffmpeg-static",
      "onnxruntime-node",
      "protobufjs",
      "sharp",
      "sodium-native"
    ]
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@huggingface/transformers": "3.8.1",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^4.0.3",
    "discord.js": "^14.25.1",
    "essentia.js": "^0.1.3",
    "ffmpeg-static": "^5.3.0",
    "music-metadata": "^11.12.1",
    "node-fetch": "^3.3.2",
    "onnxruntime-node": "^1.24.3",
    "opusscript": "0.0.8",
    "prism-media": "^1.3.5",
    "sherpa-onnx-node": "^1.12.28",
    "sodium-native": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.19",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --no-errors-on-unmatched"
    ],
    "*.{json,css,md}": [
      "biome format --no-errors-on-unmatched"
    ]
  }
}

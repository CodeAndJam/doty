{
  "name": "doty",
  "version": "1.0.0",
  "description": "Continuous STT + AI music recommender",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "rebuild": "electron-rebuild --only sherpa-onnx-node",
    "postinstall": "npm run rebuild",
    "dist": "npm run build && electron-builder --mac dmg",
    "pack": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.codeandiam.doty",
    "productName": "Doty",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/essentia.js/dist/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/sherpa-onnx-node",
        "to": "sherpa-onnx-node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Doty ${version}"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.2",
    "chokidar": "^3.6.0",
    "essentia.js": "^0.1.3",
    "ffmpeg-static": "^5.3.0",
    "node-fetch": "^3.3.2",
    "sherpa-onnx-node": "^1.12.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
